pkgname=bulwark-passkey
pkgver=0.0.1
pkgrel=0
pkgdesc="Virtual FIDO Device"
arch=('x86_64')
url=https://bulwark.id/
license=('MIT')
depends=('usbip' 'webkit2gtk-4.1')
makedepends=('protobuf' 'pkgconf' 'glib2' 'gtk3' 'autogen' 'autoconf' 'm4' 'automake' 'npm')
package() {
    mkdir -p "${pkgdir}/usr/bin/bulwark_passkey"
    cp ../../../output/bulwark_passkey "${pkgdir}/usr/bin/bulwark_passkey"
    cp -r ../../../linux_pkg/bulwark-passkey/usr "${pkgdir}/usr"
}